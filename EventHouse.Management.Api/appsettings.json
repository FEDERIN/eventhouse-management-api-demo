{
  "Auth": {
    "Audience": "eventhouse.management",
    "Issuer": "eventhouse.local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ManagementConnection": "Data Source=./Data/management.db"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "OpenTelemetry": {
    "Tracing": {
      "Enabled": true,
      "OtlpEndpoint": "http://jaeger:4317",
      "SamplingProbability": 1.0
    },
    "Metrics": {
      "Enabled": true
    },
    "Logging": {
      "Enabled": true,
      "OtlpEndpoint": "http://jaeger:4317"
    }
  }
}
